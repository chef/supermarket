        int web_download_count
        int api_download_count
        boolean featured
        boolean up_for_adoption
        boolean privacy
        int badges_mask
        datetime created_at
        datetime updated_at
    }

    cookbook_versions {
        int id PK
        int cookbook_id FK
        int user_id FK
        string version
        string license
        string spdx_license_url
        text description
        text readme
        string readme_extension
        text changelog
        string changelog_extension
        string tarball_file_name
        string tarball_content_type
        int tarball_file_size
        datetime tarball_updated_at
        boolean dependencies_imported
        int web_download_count
        int api_download_count
        int legacy_id
        json chef_versions
        json ohai_versions
        datetime created_at
        datetime updated_at
    }

    cookbook_dependencies {
        int id PK
        int cookbook_version_id FK
