        string version_constraint
        datetime created_at
        datetime updated_at
    }

    collaborators {
        int id PK
        int user_id FK
        int group_id FK
        int resourceable_id FK
        string resourceable_type
        datetime created_at
        datetime updated_at
    }

    contributor_requests {
        int id PK
        int organization_id FK
        int user_id FK
