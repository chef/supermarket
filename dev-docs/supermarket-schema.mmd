erDiagram
    users {
        int id PK
        string first_name
        string last_name
        string email
        string company
        int roles_mask
        string jira_username
        string twitter_username
        text public_key
        string install_preference
        string slack_username
        datetime created_at
        datetime updated_at
    }

    accounts {
        int id PK
        int user_id FK
        string uid
        string username
        string provider
        string oauth_token
        string oauth_secret
        string oauth_refresh_token
        datetime oauth_expires
    }

    categories {
        int id PK
        string name
        string slug
        datetime created_at
        datetime updated_at
    }

    cookbooks {
        int id PK
        string name
        string lowercase_name
        int category_id FK
        int user_id FK
        int replacement_id "FK (replacement_id refers back to PK)"
        boolean deprecated
        string deprecation_reason
        string source_url
        string issues_url
